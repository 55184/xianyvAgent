# ============================================
# 闲鱼AI客服 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# --- 必填配置 ---

# 免费API Key获取方式（选其一）：
# ① 硅基流动(SiliconFlow): https://cloud.siliconflow.cn → 注册送2000万tokens
#    MODEL_BASE_URL=https://api.siliconflow.cn/v1
#    MODEL_NAME=Qwen/Qwen3-32B
# ② DeepSeek: https://platform.deepseek.com → 注册送500万tokens  
#    MODEL_BASE_URL=https://api.deepseek.com/v1
#    MODEL_NAME=deepseek-chat
# ③ 阿里云百炼(通义千问): https://bailian.console.aliyun.com → 免费额度
#    MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#    MODEL_NAME=qwen-max

API_KEY=请填入你的API Key
COOKIES_STR=请填入你的闲鱼Cookie

# --- 模型配置 ---
MODEL_BASE_URL=https://api.siliconflow.cn/v1
MODEL_NAME=Qwen/Qwen3-32B

# --- 可选配置 ---
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=False
LOG_LEVEL=INFO

# --- 代理配置 ---
PROXY_ENABLED=true
PROXY_HOST=127.0.0.1
PROXY_PORT=9910
